<!DOCTYPE html>
<html lang="{{ metadata.language }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {% set isHome = page.url == "/" %}
  {% set pageTitle = title or metadata.title %}
  {% set pageDescription = description or metadata.description %}
  {% set shareImage = image or metadata.image %}

  <title>{% if isHome %}{{ metadata.title }}{% else %}{{ pageTitle }} · {{ metadata.title }}{% endif %}</title>
  <meta name="description" content="{{ pageDescription }}">
  <meta name="author" content="{{ metadata.author.name }}">
  <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">

  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="{{ metadata.title }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ metadata.url }}{{ page.url }}">
  <meta property="og:locale" content="{{ metadata.locale }}">
  {% if shareImage %}<meta property="og:image" content="{{ metadata.url }}{{ shareImage }}">{% endif %}
  {% if ogType == "article" and page.date %}<meta property="article:published_time" content="{{ page.date | dateToISO }}">
  <meta property="article:author" content="{{ metadata.author.name }}">{% endif %}

  <meta name="twitter:card" content="{{ 'summary_large_image' if shareImage else 'summary' }}">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  {% if metadata.twitter %}<meta name="twitter:site" content="{{ metadata.twitter }}">{% endif %}
  {% if shareImage %}<meta name="twitter:image" content="{{ metadata.url }}{{ shareImage }}">{% endif %}

  <meta name="theme-color" content="#fdfdfc">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <div class="page">
    <header>
      {% set wordmarkTag = "h1" if isHome else "p" %}
      <{{ wordmarkTag }} class="wordmark">
        <a href="/" aria-label="{{ metadata.title }} — home">
          <span class="marco">Marco</span><span class="tan">Tan<span class="gents">(gents)</span></span>
        </a>
      </{{ wordmarkTag }}>
      <nav aria-label="Primary">
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main id="main">
      {{ content | safe }}
    </main>

    <footer>
      <p>© 2026</p>
    </footer>
  </div>
</body>
</html>
