---
layout: base.njk
---

<a class="post-back" href="/"><span aria-hidden="true">←</span> Back</a>

<article>
  <h1>{{ title }}</h1>
  <time datetime="{{ page.date | dateToISO }}">
    {{ page.date | readableDate }}
  </time>

  <div class="post-content">
    {{ content | safe }}
  </div>
</article>

{%- set olderPost = collections.posts | getPreviousCollectionItem %}
{%- set newerPost = collections.posts | getNextCollectionItem %}
{%- if olderPost or newerPost %}
<nav class="post-nav" aria-label="Post navigation">
  {%- if olderPost %}
  <a class="post-nav__link post-nav__prev" href="{{ olderPost.url }}" rel="prev">
    <span class="post-nav__dir"><span aria-hidden="true">←</span> Older</span>
    <span class="post-nav__title">{{ olderPost.data.title }}</span>
  </a>
  {%- endif %}
  {%- if newerPost %}
  <a class="post-nav__link post-nav__next" href="{{ newerPost.url }}" rel="next">
    <span class="post-nav__dir">Newer <span aria-hidden="true">→</span></span>
    <span class="post-nav__title">{{ newerPost.data.title }}</span>
  </a>
  {%- endif %}
</nav>
{%- endif %}